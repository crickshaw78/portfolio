# =======================================================
#  crickshaw.dev — Apache / DailyRazor config
# =======================================================

# ---- Default document ----
DirectoryIndex index.html

# ---- Custom 404 ----
ErrorDocument 404 /404.html

# =======================================================
#  Redirects: force HTTPS + canonical host (crickshaw.dev)
# =======================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force non-www (www.crickshaw.dev -> crickshaw.dev)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # Strip trailing index.html for cleaner URLs (/notes/index.html -> /notes/)
  RewriteCond %{THE_REQUEST} \s/+(.*?)index\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
</IfModule>

# =======================================================
#  Security headers
# =======================================================
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# =======================================================
#  Compression
# =======================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2
</IfModule>

# =======================================================
#  Cache control
# =======================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short cache so content updates propagate
  ExpiresByType text/html "access plus 1 hour"

  # CSS / JS — long cache (bust via filename if needed)
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType text/javascript "access plus 30 days"

  # Images / fonts — long cache
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"

  # XML — sitemap etc.
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
</IfModule>

# =======================================================
#  MIME types (in case host doesn't set them)
# =======================================================
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType application/manifest+json .webmanifest
  AddType font/woff2 .woff2
</IfModule>

# =======================================================
#  Protect dotfiles and backups
# =======================================================
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
<FilesMatch "\.(bak|old|swp|log)$">
  Require all denied
</FilesMatch>
